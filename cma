        esac
    done
    write_capture prevention preventions.jsonl "$description" \
        miss_id "$miss_id" warning_id "$warning_id"
}

# ---------------------------------------------------------------------------
# Operational verbs (stubbed for v1.0-dev)
# ---------------------------------------------------------------------------

cmd_surface() {
    local surface="" file="" type="" limit="10" log_event=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --surface) surface="$2"; shift 2 ;;
            --file) file="$2"; shift 2 ;;
            --type) type="$2"; shift 2 ;;
            --limit) limit="$2"; shift 2 ;;
            --no-log) log_event=false; shift ;;
            *) echo "cma surface: unknown flag: $1" >&2; usage_for surface; exit 1 ;;
        esac
    done

    local log_arg="log"
    $log_event || log_arg="nolog"

    python3 - "$CMA_DIR" "$surface" "$file" "$type" "$limit" "$log_arg" <<'PYEOF'
import json, os, sys, time
from glob import glob

data_dir, surface_filter, file_filter, type_filter, limit_str, log_arg = sys.argv[1:]
limit = int(limit_str) if limit_str else 10
should_log = (log_arg == "log")

captures = []
for path in sorted(glob(os.path.join(data_dir, "*.jsonl"))):
    # Don't include surface_events.jsonl in the captures-to-surface set
    if os.path.basename(path) == "surface_events.jsonl":
        continue
    corrupted = 0
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                corrupted += 1
                continue
            # Skip retirement records when surfacing
            if rec.get("type") == "retirement":
                continue
            captures.append(rec)
    if corrupted:
        print("cma: skipped {} corrupted line(s) in {}".format(corrupted, os.path.basename(path)), file=sys.stderr)

def matches(rec):
    if type_filter and rec.get("type") != type_filter:
        return False

    # Decisions: applies-when matches against context keywords. A decision
    # with applies-when="auth db" surfaces whenever surface or file context
    # contains "auth" or "db", even if the decision's own surface differs.
    # This closes the decision-surfacing loop (decisions surface at action
    # time when conditions match, not just by stored surface field).
    if rec.get("type") == "decision":
        applies_when = (rec.get("applies_when") or "").lower()
        if applies_when:
            keywords = [k for k in applies_when.replace(",", " ").split() if k]
            context_parts = []
            if surface_filter: context_parts.append(surface_filter.lower())
            if file_filter: context_parts.append(file_filter.lower())
            context_str = " ".join(context_parts)
            if context_str and any(kw in context_str for kw in keywords):
                return True

    if surface_filter and rec.get("surface") != surface_filter:
        return False
    if file_filter:
        files = rec.get("files", "")
        if file_filter not in files:
            return False
    return True

filtered = [r for r in captures if matches(r)]
filtered.sort(key=lambda r: r.get("timestamp", ""), reverse=True)
filtered = filtered[:limit]

# Log the surface event so cma stats --leaks can later detect failures
# that occurred despite a relevant warning being surfaced.
if should_log:
    from datetime import datetime, timezone
    _now = datetime.now(timezone.utc)
    event_id = "{}-{}".format(_now.strftime("%Y%m%d-%H%M%S"), os.urandom(4).hex())
    event = {
        "schema_version": "1.0",
        "type": "surface_event",
        "id": event_id,
        "timestamp": _now.strftime("%Y-%m-%dT%H:%M:%S.%fZ"),
        "filter_surface": surface_filter,
        "filter_file": file_filter,
        "filter_type": type_filter,
        "filter_limit": limit,
        "matched": [
            {
                "id": r.get("id"),
                "type": r.get("type"),
                "surface": r.get("surface", ""),
                "fm": r.get("fm", ""),
            }
            for r in filtered
        ],
    }
    log_path = os.path.join(data_dir, "surface_events.jsonl")
    with open(log_path, "a") as f:
        f.write(json.dumps(event) + "\n")

if not filtered:
    print("No captures match.")
    sys.exit(0)

for rec in filtered:
    type_label = rec.get("type", "?")
    rec_id = rec.get("id", "?")
    surface = rec.get("surface", "")
    desc = rec.get("description", "")
    desc = " ".join(desc.split())
    if len(desc) > 96:
        desc = desc[:93] + "..."
    surface_part = " [" + surface + "]" if surface else ""
    print(type_label.ljust(10) + " " + rec_id + surface_part)
    print("           " + desc)
    print()
PYEOF
}

cmd_distill() {
    local retire_pattern="" review_mode=false
    local learning="" scope="" surface=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --retire) retire_pattern="$2"; shift 2 ;;
            --review) review_mode=true; shift ;;
            --scope) scope="$2"; shift 2 ;;
            --surface) surface="$2"; shift 2 ;;
            -*) echo "cma distill: unknown flag: $1" >&2; usage_for distill; exit 1 ;;
            *)
                if [[ -z "$learning" ]]; then learning="$1"; else
                    echo "cma distill: extra positional argument: $1" >&2; exit 1
                fi
                shift ;;
        esac
    done

    if $review_mode; then
        python3 - "$CMA_DIR" <<'PYEOF'
import json, os, sys
from collections import Counter

data_dir = sys.argv[1]
groups = Counter()
total = 0

misses_path = os.path.join(data_dir, "misses.jsonl")
corrupted = 0
if os.path.exists(misses_path):
    with open(misses_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                corrupted += 1
                continue
            key = (rec.get("surface", ""), rec.get("fm", ""))
            groups[key] += 1
            total += 1

if corrupted:
    print("cma: skipped {} corrupted line(s) in misses.jsonl".format(corrupted), file=sys.stderr)

if total == 0:
    print("No misses recorded yet.")
    sys.exit(0)

candidates = sorted(
    [(k, v) for k, v in groups.items() if v >= 2],
    key=lambda x: x[1], reverse=True
)

if not candidates:
    print("{} miss(es) recorded; no patterns recur yet (need 2+ per surface/fm).".format(total))
    sys.exit(0)

print("Distillation candidates from {} miss(es):".format(total))
print()
for (surface, fm), count in candidates:
    s = surface if surface else "(no surface)"
    f = fm if fm else "(no fm)"
    print("  {}x  surface={}  fm={}".format(count, s, f))
print()
print("Use 'cma distill <learning>' to promote a rule for one of these patterns.")
PYEOF
        return 0
    fi

    if [[ -n "$retire_pattern" ]]; then
        python3 - "$CMA_DIR" "$retire_pattern" <<'PYEOF'
import json, os, sys, time

data_dir, pattern = sys.argv[1:3]
core_path = os.path.join(data_dir, "core.jsonl")

if not os.path.exists(core_path):
    print("No core learnings to retire.")
    sys.exit(0)

retired_ids = set()
with open(core_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        if rec.get("type") == "retirement":
            retired_ids.add(rec.get("retires"))

matched = []
with open(core_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        if rec.get("type") != "core":
            continue
        rid = rec.get("id")
        if rid in retired_ids:
            continue
        if pattern in rec.get("description", ""):
            matched.append(rec)

if not matched:
    print("No active core learnings matched: {}".format(pattern))
    sys.exit(0)

from datetime import datetime, timezone
_now = datetime.now(timezone.utc)
now = _now.strftime("%Y-%m-%dT%H:%M:%S.%fZ")
with open(core_path, "a") as f:
    for rec in matched:
        retire_id = "{}-{}".format(_now.strftime("%Y%m%d-%H%M%S"), os.urandom(4).hex())
        retirement = {
            "type": "retirement",
            "id": retire_id,
            "timestamp": now,
            "retires": rec.get("id"),
            "pattern": pattern,
        }
        f.write(json.dumps(retirement) + "\n")

print("Retired {} core learning(s) matching: {}".format(len(matched), pattern))
for rec in matched:
    desc = rec.get("description", "")
    if len(desc) > 70:
        desc = desc[:67] + "..."
    print("  - {} {}".format(rec.get("id"), desc))
PYEOF
        return 0
    fi

    if [[ -z "$learning" ]]; then
        usage_for distill
        exit 1
    fi

    write_capture core core.jsonl "$learning" \
        scope "$scope" surface "$surface"
}

cmd_stats() {
    local view="" recurrence_mode=false leaks_mode=false behavior_mode=false evidence_mode=false
    local window_days=30 window_explicit=false json_mode=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --rejections) view="rejection"; shift ;;
            --preventions) view="prevention"; shift ;;
            --recurrence) recurrence_mode=true; shift ;;
            --leaks) leaks_mode=true; shift ;;
            --behavior) behavior_mode=true; shift ;;
            --evidence) evidence_mode=true; shift ;;
            --json) json_mode=true; shift ;;
            --window)
                if ! [[ "${2:-}" =~ ^[0-9]+$ ]] || [[ "${2:-0}" -lt 1 ]]; then
                    echo "cma stats: --window requires a positive integer (days)" >&2; exit 1
                fi
                window_days="$2"; window_explicit=true; shift 2 ;;
            *) echo "cma stats: unknown flag: $1" >&2; usage_for stats; exit 1 ;;
        esac
    done

    if $evidence_mode; then
        local json_arg="prose"
        $json_mode && json_arg="json"
        python3 - "$CMA_DIR" "$window_days" "$json_arg" <<'PYEOF'
import json, os, sys
from collections import Counter
from datetime import datetime, timedelta, timezone

data_dir = sys.argv[1]
window_days = int(sys.argv[2])
output_format = sys.argv[3]  # "prose" or "json"

cutoff = datetime.now(timezone.utc) - timedelta(days=window_days)
cutoff_iso = cutoff.strftime("%Y-%m-%dT%H:%M:%S.%fZ")

# Records written by older builds may use second-precision
# timestamps. Normalize before any lexicographic comparison so
# mixed-format corpora order correctly.
def norm_ts(ts):
    if not ts:
        return ""
    return ts if "." in ts else ts.replace("Z", ".000000Z")

def load(path):
    out = []
    if not os.path.exists(path):
        return out
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                out.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    return out

misses = load(os.path.join(data_dir, "misses.jsonl"))
preventions = load(os.path.join(data_dir, "preventions.jsonl"))
events = load(os.path.join(data_dir, "surface_events.jsonl"))

def in_window(rec):
    return norm_ts(rec.get("timestamp", "")) >= cutoff_iso

misses_w = [m for m in misses if in_window(m)]
preventions_w = [p for p in preventions if in_window(p)]

leaks = []
for miss in misses_w:
    miss_ts = norm_ts(miss.get("timestamp", ""))
    miss_surface = miss.get("surface", "")
    miss_fm = miss.get("fm", "")
    if not miss_surface and not miss_fm:
        continue
    for event in events:
        if norm_ts(event.get("timestamp", "")) >= miss_ts:
            continue
        for matched in event.get("matched", []):
            if (matched.get("surface") == miss_surface and
                matched.get("fm") == miss_fm and miss_surface):
                leaks.append(miss)
                break
        else:
            continue
        break

prevented_count = len(preventions_w)
leak_count = len(leaks)

# Loop-closure evidence: a prevention is evidence the loop fired
# only when a surface event for the linked miss occurred between
# the miss timestamp and the prevention timestamp. Operator
# self-attestation without a surfaced warning is captured (the
# total count above) but does not inflate the closure rate.
miss_by_id = {m.get("id"): m for m in misses if m.get("id")}
evidenced_preventions = []
for prev in preventions_w:
    target = prev.get("miss_id")
    if not target:
        continue
    m = miss_by_id.get(target)
    if m is None:
        continue
    miss_ts = norm_ts(m.get("timestamp", ""))
    prev_ts = norm_ts(prev.get("timestamp", ""))
    if not miss_ts or not prev_ts or miss_ts >= prev_ts:
        continue
    surfaced_between = False
    for event in events:
        ev_ts = norm_ts(event.get("timestamp", ""))
        if not (miss_ts <= ev_ts < prev_ts):
            continue
        for matched in event.get("matched", []):
            if matched.get("id") == target:
                surfaced_between = True
                break
        if surfaced_between:
            break
    if surfaced_between:
        evidenced_preventions.append(prev)

evidenced_count = len(evidenced_preventions)
closure_denom = evidenced_count + leak_count
closure_rate = (evidenced_count / closure_denom) if closure_denom > 0 else None

groups = Counter()
for m in misses_w:
    groups[(m.get("surface", ""), m.get("fm", ""))] += 1
recurring = sorted(
    [(k, v) for k, v in groups.items() if v >= 2],
    key=lambda x: x[1], reverse=True
)
linked = sum(1 for p in preventions_w if p.get("miss_id"))

if output_format == "json":
    out = {
        "schema_version": "1.0",
        "window_days": window_days,
        "generated_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "preventions": prevented_count,
        "preventions_linked_to_miss": linked,
        "preventions_evidenced": evidenced_count,
        "leaks": leak_count,
        "loop_closure_rate": closure_rate,
        "recurring": [
            {"surface": s, "fm": f, "count": n}
            for (s, f), n in recurring
        ],
    }
    print(json.dumps(out, indent=2))
    sys.exit(0)

print("Compound practice evidence (trailing {} days)".format(window_days))
print()
print("  Preventions captured:        {}".format(prevented_count))
print("    of which linked to a miss: {}".format(linked))
print("    of which evidenced:        {}".format(evidenced_count))
print("  Leaks:                       {}".format(leak_count))
if closure_denom == 0:
    print("  Loop closure rate:           -- (no evidenced preventions or leaks in window)")
else:
    print("  Loop closure rate:           {:.0%}  ({}/{})".format(
        closure_rate, evidenced_count, closure_denom))
print()

if recurring:
    print("  Recurring patterns in window ({}):".format(len(recurring)))
    for (s, f), n in recurring[:5]:
        s = s if s else "(no surface)"
        f = f if f else "(no fm)"
        print("    {}x  surface={}  fm={}".format(n, s, f))
    print()

if closure_denom == 0:
    print("  No loop-closure evidence yet. A prevention is evidenced when")
    print("  the miss it links to (via --miss-id) was surfaced by cma between")
    print("  the miss's capture and the prevention's capture. Without that")
    print("  chain, a prevention is operator self-attestation and is counted")
    print("  above but does not enter the closure rate. Wire the hook (or run")
    print("  cma surface manually) so surface events exist, and link each")
    print("  prevention with cma prevented --miss-id <id>.")
else:
    print("  Loop closure rate measures: among moments where a prior miss")
    print("  was actually surfaced before the next attempt, what fraction")
    print("  closed (an evidenced prevention) versus leaked (the miss")
    print("  recurred). Self-attested preventions without surface-event")
    print("  evidence are captured separately and do not enter this rate.")
PYEOF
        return 0
    fi

    if $behavior_mode; then
        python3 - "$CMA_DIR" <<'PYEOF'
import json, os, sys
from collections import defaultdict

data_dir = sys.argv[1]
misses_path = os.path.join(data_dir, "misses.jsonl")

if not os.path.exists(misses_path):
    print("No misses recorded yet.")
    sys.exit(0)

with_texture = []
total = 0
with open(misses_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        total += 1
        if rec.get("intended") or rec.get("corrected"):
            with_texture.append(rec)

if not with_texture:
    print("{} miss(es) recorded; none have intended/corrected texture yet.".format(total))
    print("Capture with --intended and --corrected to enable behavior-layer analysis.")
    sys.exit(0)

groups = defaultdict(list)
for rec in with_texture:
    key = (rec.get("surface", ""), rec.get("fm", ""))
    groups[key].append(rec)

print("Behavior-layer signals from {} miss(es) ({} with texture):".format(total, len(with_texture)))
print()

sorted_groups = sorted(groups.items(), key=lambda x: len(x[1]), reverse=True)

def truncate(text, n=70):
    text = " ".join(text.split())
    return text if len(text) <= n else text[:n-3] + "..."

for (surface, fm), records in sorted_groups:
    s = surface if surface else "(no surface)"
    f = fm if fm else "(no fm)"
    print("  surface={}  fm={}  ({} with texture)".format(s, f, len(records)))

    recent = max(records, key=lambda r: r.get("timestamp", ""))
    intended = recent.get("intended", "").strip()
    corrected = recent.get("corrected", "").strip()

    if intended:
        print("    intended:  {}".format(truncate(intended)))
    if corrected:
        print("    corrected: {}".format(truncate(corrected)))
    print()

print("Behavior-layer analysis: each group shows where the operator had to pivot")
print("from an initial impulse to a different action. Recurring pivots indicate")
print("patterns where surfaced warnings consistently change operator behavior.")
PYEOF
        return 0
    fi

    if $leaks_mode; then
        python3 - "$CMA_DIR" <<'PYEOF'
import json, os, sys

data_dir = sys.argv[1]

def load_jsonl(path):
    records = []
    if not os.path.exists(path):
        return records
    corrupted = 0
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                records.append(json.loads(line))
            except json.JSONDecodeError:
                corrupted += 1
                continue
    if corrupted:
        print("cma: skipped {} corrupted line(s) in {}".format(corrupted, os.path.basename(path)), file=sys.stderr)
    return records

# Records written by older builds may use second-precision
# timestamps. Normalize before any lexicographic comparison so
# mixed-format corpora order correctly.
def norm_ts(ts):
    if not ts:
        return ""
    return ts if "." in ts else ts.replace("Z", ".000000Z")

misses = load_jsonl(os.path.join(data_dir, "misses.jsonl"))
events = load_jsonl(os.path.join(data_dir, "surface_events.jsonl"))
preventions = load_jsonl(os.path.join(data_dir, "preventions.jsonl"))

# Build (surface, fm) -> prevention count by following prevention.miss_id
# back to the miss's surface/fm. A prevention without miss_id cannot be
# attributed to a pair; counted separately as unlinked_preventions.
miss_by_id = {m.get("id"): m for m in misses}
caught_by_pair = {}
unlinked_preventions = 0
for prev in preventions:
    target = prev.get("miss_id")
    if not target:
        unlinked_preventions += 1
        continue
    m = miss_by_id.get(target)
    if m is None:
        unlinked_preventions += 1
        continue
    key = (m.get("surface", ""), m.get("fm", ""))
    caught_by_pair[key] = caught_by_pair.get(key, 0) + 1

if not events:
    print("No surface events recorded yet.")
    print("Leaks are detected by joining misses against prior surface events;")
    print("run 'cma surface' (manually or via hook) before failures occur to populate this signal.")
    sys.exit(0)

leaks = []
weak_leaks = []
for miss in misses:
    miss_ts = norm_ts(miss.get("timestamp", ""))
    miss_surface = miss.get("surface", "")
    miss_fm = miss.get("fm", "")
    if not miss_surface and not miss_fm:
        continue  # nothing to match against
    strong_hit = None
    weak_hit = None
    for event in events:
        event_ts = norm_ts(event.get("timestamp", ""))
        if event_ts >= miss_ts:
            continue  # event after miss
        for matched in event.get("matched", []):
            m_surface = matched.get("surface", "")
            m_fm = matched.get("fm", "")
            # Strong: surface and fm both present and equal on both sides.
            if (miss_surface and m_surface == miss_surface and
                miss_fm and m_fm and m_fm == miss_fm):
                strong_hit = (event, matched)
                break
            # Weak: surface matches but fm absent on one or both sides.
            # Surface must be truthy on both ends; without surface there
            # is no shared dimension to anchor the join on.
            if (weak_hit is None and miss_surface and
                m_surface == miss_surface and (not miss_fm or not m_fm)):
                weak_hit = (event, matched)
        if strong_hit:
            break
    if strong_hit:
        leaks.append((miss, strong_hit[0], strong_hit[1]))
    elif weak_hit:
        weak_leaks.append((miss, weak_hit[0], weak_hit[1]))

if not leaks and not weak_leaks:
    print("{} miss(es), {} surface event(s); no leaks detected.".format(len(misses), len(events)))
    print("(A leak is a miss whose surface/fm was already surfaced by a prior event.)")
    sys.exit(0)

if leaks:
    print("{} leak(s): failures despite a relevant warning being surfaced earlier.".format(len(leaks)))
    print()
    for miss, event, matched in leaks:
        desc = miss.get("description", "")
        desc = " ".join(desc.split())
        if len(desc) > 70:
            desc = desc[:67] + "..."
        pair = (miss.get("surface", ""), miss.get("fm", ""))
        caught = caught_by_pair.get(pair, 0)
        print("  Miss:    {} {}".format(miss.get("id"), desc))
        print("    surface={}  fm={}".format(miss.get("surface", ""), miss.get("fm", "")))
        print("  Was surfaced by event {} at {}".format(event.get("id"), event.get("timestamp")))
        print("    via capture {} (same surface/fm)".format(matched.get("id")))
        print("  Caught on this pair: {}".format(caught))
        print()

if weak_leaks:
    print("{} weak signal(s): surface matched but fm absent on one side.".format(len(weak_leaks)))
    print("(Weak signals are not leaks. Capture fm consistently to upgrade them.)")
    print()
    for miss, event, matched in weak_leaks:
        desc = miss.get("description", "")
        desc = " ".join(desc.split())
        if len(desc) > 70:
            desc = desc[:67] + "..."
        miss_fm_display = miss.get("fm", "") or "(none)"
        matched_fm_display = matched.get("fm", "") or "(none)"
        print("  Miss:    {} {}".format(miss.get("id"), desc))
        print("    surface={}  fm={}".format(miss.get("surface", ""), miss_fm_display))
        print("  Was surfaced by event {} at {}".format(event.get("id"), event.get("timestamp")))
        print("    via capture {} (surface={}, fm={})".format(
            matched.get("id"), matched.get("surface", ""), matched_fm_display))
        print()
PYEOF
        return 0
    fi

    if $recurrence_mode; then
        # Recurrence defaults to all-time so the existing behavior
        # is preserved when --window is not passed. An explicit
        # --window N scopes it to the trailing window.
        local rec_window=0
        $window_explicit && rec_window=$window_days
        python3 - "$CMA_DIR" "$rec_window" <<'PYEOF'
import json, os, sys
from collections import Counter
from datetime import datetime, timedelta, timezone

data_dir = sys.argv[1]
window_days = int(sys.argv[2])

if window_days > 0:
    cutoff = datetime.now(timezone.utc) - timedelta(days=window_days)
    cutoff_iso = cutoff.strftime("%Y-%m-%dT%H:%M:%S.%fZ")
else:
    cutoff_iso = ""  # match everything

def norm_ts(ts):
    if not ts:
        return ""
    return ts if "." in ts else ts.replace("Z", ".000000Z")

groups = Counter()
total = 0
misses_index = {}

misses_path = os.path.join(data_dir, "misses.jsonl")
corrupted = 0
if os.path.exists(misses_path):
    with open(misses_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                corrupted += 1
                continue
            if cutoff_iso and norm_ts(rec.get("timestamp", "")) < cutoff_iso:
                continue
            key = (rec.get("surface", ""), rec.get("fm", ""))
            groups[key] += 1
            total += 1
            if rec.get("id"):
                misses_index[rec["id"]] = rec

if corrupted:
    print("cma: skipped {} corrupted line(s) in misses.jsonl".format(corrupted), file=sys.stderr)

# Caught-by-pair join: a prevention with miss_id pointing at a known
# miss attributes one catch to that miss's (surface, fm) pair. Without
# this signal the recurrence view says "this prevention is not working"
# even when most attempts on the pair are caught and a few leaked.
caught_by_pair = {}
preventions_path = os.path.join(data_dir, "preventions.jsonl")
if os.path.exists(preventions_path):
    with open(preventions_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                prev = json.loads(line)
            except json.JSONDecodeError:
                continue
            target = prev.get("miss_id")
            if not target:
                continue
            m = misses_index.get(target)
            if m is None:
                continue
            key = (m.get("surface", ""), m.get("fm", ""))
            caught_by_pair[key] = caught_by_pair.get(key, 0) + 1

if total == 0:
    print("No misses recorded yet.")
    sys.exit(0)

recurring = sorted(
    [(k, v) for k, v in groups.items() if v >= 2],
    key=lambda x: x[1], reverse=True
)

scope = "trailing {} days".format(window_days) if window_days > 0 else "all time"

if not recurring:
    print("{} miss(es) recorded in {}; no patterns are recurring (threshold: 2+ per surface/fm pair).".format(total, scope))
    sys.exit(0)

print("Recurring failure patterns from {} miss(es) ({}):".format(total, scope))
print()
for (surface, fm), count in recurring:
    s = surface if surface else "(no surface)"
    f = fm if fm else "(no fm)"
    caught = caught_by_pair.get((surface, fm), 0)
    denom = count + caught
    if caught:
        rate = caught / denom
        print("  {}x  surface={}  fm={}   (caught: {}, catch-rate: {:.0%})".format(
            count, s, f, caught, rate))
    else:
        print("  {}x  surface={}  fm={}   (caught: 0)".format(count, s, f))
print()
print("Recurrence indicates the prevention is not closing the loop fully.")
print("A high catch-rate alongside recurrence means the warning works most of")
print("the time but slips occasionally; sharpen the trigger. A zero catch-rate")
print("means the warning is not firing at the right moment, or no prevention")
print("has been captured yet.")
PYEOF
        return 0
    fi

    if [[ -n "$view" ]]; then
        cmd_surface --type "$view"
        return 0
    fi

    # Default summary
    echo "Compound practice summary"
    echo ""
    local total=0
    for type in misses decisions rejections preventions core; do
        local count=0
        if [[ -f "$CMA_DIR/$type.jsonl" ]]; then
            count=$(wc -l < "$CMA_DIR/$type.jsonl" | tr -d ' ')
        fi
        printf "  %-13s %s\n" "$type" "$count"
        total=$((total + count))
    done
    echo ""
    printf "  %-13s %s\n" "total" "$total"
}

