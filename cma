warn_if_storage_risky() {
    # Append atomicity is reliable on local POSIX filesystems but
    # weaker on network filesystems (NFS without flock, SMB) and on
    # cloud-sync directories that watch+rewrite files (Dropbox,
    # iCloud Drive, OneDrive, Google Drive). Warn rather than block
    # so operators can override after reading the rationale in
    # DATA.md.
    local dir="$1"
    case "$dir" in
        *Dropbox*|*"iCloud Drive"*|*OneDrive*|*"Google Drive"*|*GoogleDrive*|*pCloudDrive*|*Sync/*)
            echo "cma: warning: $dir looks like a cloud-sync path." >&2
            echo "cma: append atomicity is not guaranteed on synced directories;" >&2
            echo "cma: see DATA.md (Storage requirements) for the rationale." >&2
            return 0
            ;;
    esac
    # Try to detect a network filesystem type via df (best-effort;
    # not all systems support -T). Silent on failure.
    local fs
    fs=$(df -T "$dir" 2>/dev/null | awk 'NR==2 {print tolower($2)}' || true)
    case "$fs" in
        nfs*|nfs4|cifs|smbfs|fuse.sshfs|fuseblk)
            echo "cma: warning: $dir is on a $fs filesystem." >&2
            echo "cma: append atomicity is not guaranteed on network filesystems;" >&2
            echo "cma: see DATA.md (Storage requirements) for the rationale." >&2
            ;;
    esac
}

cmd_init() {
    mkdir -p "$CMA_DIR"
    warn_if_storage_risky "$CMA_DIR"
    cat > "$CMA_DIR/README.md" <<EOF
# cma data directory

This directory is the durable corpus of compound practice. The schema,
layout, atomicity guarantees, and migration policy are documented at:

  https://github.com/Clarethium/cma/blob/main/DATA.md

Files in this directory:

  misses.jsonl         Captures of failures
  decisions.jsonl      Captures of architectural choices
  rejections.jsonl     Captures of eliminated options
  preventions.jsonl    Captures of caught warnings
  core.jsonl           Distilled learnings (and retirements)
  surface_events.jsonl Surface query events (logged by cma surface)

All files are append-only JSONL. Back up by copying this directory.

To inspect:
  cma stats       Summary dashboard
  cma surface     Query by filter

cma version that wrote this README: $VERSION
Schema version: $SCHEMA_VERSION
EOF
    echo "Initialized cma data directory at $CMA_DIR"
    echo "See $CMA_DIR/README.md for layout."
}

cmd_help() {
    cat <<EOF
cma $VERSION - compound practice loop

Captures (write):
  cma miss <description> [--surface <s>] [--fm <fm>] [--files <f>]
  cma decision <description> [--surface <s>] [--applies-when <p>]
  cma reject <description> [--surface <s>] [--revisit-when <t>]
  cma prevented <description> [--miss-id <id>] [--warning-id <id>]

Operations:
  cma surface [--surface <s>] [--file <f>] [--type <t>] [--limit <n>]
  cma distill <learning> [--scope <s>] [--surface <s>] | --retire <p> | --review
  cma stats [--rejections] [--leaks] [--preventions] [--recurrence] [--behavior]
  cma stats --evidence [--window <days>]

Setup:
  cma init                Create the data directory with a README

Other:
  cma --version
  cma --help

Specification: DESIGN.md in this repository.
Architecture:  ARCHITECTURE.md in this repository.
Schema:        DATA.md in this repository.
Methodology:   https://github.com/Clarethium/lodestone

Data directory: \$CMA_DIR (default: ~/.cma)
EOF
}

case "${1:-}" in
    miss)        shift; cmd_miss "$@" ;;
    decision)    shift; cmd_decision "$@" ;;
    reject)      shift; cmd_reject "$@" ;;
    prevented)   shift; cmd_prevented "$@" ;;
    surface)     shift; cmd_surface "$@" ;;
    distill)     shift; cmd_distill "$@" ;;
    stats)       shift; cmd_stats "$@" ;;
    init)        shift; cmd_init "$@" ;;
    --version|-v) echo "cma $VERSION" ;;
    --help|-h|help|"") cmd_help ;;
    *)
        echo "cma: unknown command: $1" >&2
        echo "Run 'cma --help' for usage." >&2
        exit 1
        ;;
esac
