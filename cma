        return 0
    fi

    if [[ -z "$learning" ]]; then
        usage_for distill
        exit 1
    fi

    write_capture core core.jsonl "$learning" \
        scope "$scope" surface "$surface"
}

cmd_stats() {
    local view="" recurrence_mode=false leaks_mode=false behavior_mode=false evidence_mode=false
    local window_days=30
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --rejections) view="rejection"; shift ;;
            --preventions) view="prevention"; shift ;;
            --recurrence) recurrence_mode=true; shift ;;
            --leaks) leaks_mode=true; shift ;;
            --behavior) behavior_mode=true; shift ;;
            --evidence) evidence_mode=true; shift ;;
            --window)
                if ! [[ "${2:-}" =~ ^[0-9]+$ ]] || [[ "${2:-0}" -lt 1 ]]; then
                    echo "cma stats: --window requires a positive integer (days)" >&2; exit 1
                fi
                window_days="$2"; shift 2 ;;
            *) echo "cma stats: unknown flag: $1" >&2; usage_for stats; exit 1 ;;
        esac
    done

    if $evidence_mode; then
        python3 - "$CMA_DIR" "$window_days" <<'PYEOF'
import json, os, sys
from collections import Counter
from datetime import datetime, timedelta, timezone

data_dir = sys.argv[1]
window_days = int(sys.argv[2])

cutoff = datetime.now(timezone.utc) - timedelta(days=window_days)
cutoff_iso = cutoff.strftime("%Y-%m-%dT%H:%M:%SZ")

def load(path):
    out = []
    if not os.path.exists(path):
        return out
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                out.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    return out

misses = load(os.path.join(data_dir, "misses.jsonl"))
preventions = load(os.path.join(data_dir, "preventions.jsonl"))
events = load(os.path.join(data_dir, "surface_events.jsonl"))

def in_window(rec):
    return rec.get("timestamp", "") >= cutoff_iso

misses_w = [m for m in misses if in_window(m)]
preventions_w = [p for p in preventions if in_window(p)]

leaks = []
for miss in misses_w:
    miss_ts = miss.get("timestamp", "")
    miss_surface = miss.get("surface", "")
    miss_fm = miss.get("fm", "")
    if not miss_surface and not miss_fm:
        continue
    for event in events:
        if event.get("timestamp", "") >= miss_ts:
            continue
        for matched in event.get("matched", []):
            if (matched.get("surface") == miss_surface and
                matched.get("fm") == miss_fm and miss_surface):
                leaks.append(miss)
                break
        else:
            continue
        break

prevented_count = len(preventions_w)
leak_count = len(leaks)
denom = prevented_count + leak_count

print("Compound practice evidence (trailing {} days)".format(window_days))
print()
print("  Preventions:     {}".format(prevented_count))
print("  Leaks:           {}".format(leak_count))
if denom == 0:
    print("  Prevention rate: -- (no preventions or leaks in window)")
else:
    rate = prevented_count / denom
    print("  Prevention rate: {:.0%}  ({}/{})".format(rate, prevented_count, denom))
print()

groups = Counter()
for m in misses_w:
    groups[(m.get("surface", ""), m.get("fm", ""))] += 1
recurring = sorted(
    [(k, v) for k, v in groups.items() if v >= 2],
    key=lambda x: x[1], reverse=True
)
if recurring:
    print("  Recurring patterns in window ({}):".format(len(recurring)))
    for (s, f), n in recurring[:5]:
        s = s if s else "(no surface)"
        f = f if f else "(no fm)"
        print("    {}x  surface={}  fm={}".format(n, s, f))
    print()

if prevented_count:
    linked = sum(1 for p in preventions_w if p.get("miss_id"))
    print("  Preventions with miss_id linkage: {}/{}".format(linked, prevented_count))
    print()

if denom == 0:
    print("  No evidence yet. The signal computes once preventions or leaks")
    print("  accumulate in the window. Run cma surface (or wire the hook) so")
    print("  surface events exist before misses, which is what enables leak")
    print("  detection. Capture preventions with cma prevented when a")
    print("  surfaced warning changes behavior.")
else:
    print("  Prevention rate measures: of moments where the loop could close")
    print("  (a relevant capture existed and was surfaced before the action),")
    print("  what fraction closed (prevention captured) vs leaked (a miss")
    print("  recurred despite the warning).")
PYEOF
        return 0
    fi

    if $behavior_mode; then
        python3 - "$CMA_DIR" <<'PYEOF'
import json, os, sys
from collections import defaultdict

data_dir = sys.argv[1]
misses_path = os.path.join(data_dir, "misses.jsonl")

if not os.path.exists(misses_path):
    print("No misses recorded yet.")
    sys.exit(0)

with_texture = []
total = 0
with open(misses_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        total += 1
        if rec.get("intended") or rec.get("corrected"):
            with_texture.append(rec)

if not with_texture:
    print("{} miss(es) recorded; none have intended/corrected texture yet.".format(total))
    print("Capture with --intended and --corrected to enable behavior-layer analysis.")
    sys.exit(0)

groups = defaultdict(list)
for rec in with_texture:
    key = (rec.get("surface", ""), rec.get("fm", ""))
    groups[key].append(rec)

print("Behavior-layer signals from {} miss(es) ({} with texture):".format(total, len(with_texture)))
print()

sorted_groups = sorted(groups.items(), key=lambda x: len(x[1]), reverse=True)

def truncate(text, n=70):
    text = " ".join(text.split())
    return text if len(text) <= n else text[:n-3] + "..."

for (surface, fm), records in sorted_groups:
    s = surface if surface else "(no surface)"
    f = fm if fm else "(no fm)"
    print("  surface={}  fm={}  ({} with texture)".format(s, f, len(records)))

    recent = max(records, key=lambda r: r.get("timestamp", ""))
    intended = recent.get("intended", "").strip()
    corrected = recent.get("corrected", "").strip()

    if intended:
        print("    intended:  {}".format(truncate(intended)))
    if corrected:
        print("    corrected: {}".format(truncate(corrected)))
    print()

print("Behavior-layer analysis: each group shows where the operator had to pivot")
print("from an initial impulse to a different action. Recurring pivots indicate")
print("patterns where surfaced warnings consistently change operator behavior.")
PYEOF
        return 0
    fi

    if $leaks_mode; then
        python3 - "$CMA_DIR" <<'PYEOF'
import json, os, sys

data_dir = sys.argv[1]

def load_jsonl(path):
    records = []
    if not os.path.exists(path):
        return records
    corrupted = 0
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                records.append(json.loads(line))
            except json.JSONDecodeError:
                corrupted += 1
                continue
    if corrupted:
        print("cma: skipped {} corrupted line(s) in {}".format(corrupted, os.path.basename(path)), file=sys.stderr)
    return records

misses = load_jsonl(os.path.join(data_dir, "misses.jsonl"))
events = load_jsonl(os.path.join(data_dir, "surface_events.jsonl"))

if not events:
    print("No surface events recorded yet.")
    print("Leaks are detected by joining misses against prior surface events;")
    print("run 'cma surface' (manually or via hook) before failures occur to populate this signal.")
    sys.exit(0)

leaks = []
weak_leaks = []
for miss in misses:
    miss_ts = miss.get("timestamp", "")
    miss_surface = miss.get("surface", "")
    miss_fm = miss.get("fm", "")
    if not miss_surface and not miss_fm:
        continue  # nothing to match against
    strong_hit = None
    weak_hit = None
    for event in events:
        event_ts = event.get("timestamp", "")
        if event_ts >= miss_ts:
            continue  # event after miss
        for matched in event.get("matched", []):
            m_surface = matched.get("surface", "")
            m_fm = matched.get("fm", "")
            # Strong: surface and fm both present and equal on both sides.
            if (miss_surface and m_surface == miss_surface and
                miss_fm and m_fm and m_fm == miss_fm):
                strong_hit = (event, matched)
                break
            # Weak: surface matches but fm absent on one or both sides.
            # Surface must be truthy on both ends; without surface there
            # is no shared dimension to anchor the join on.
            if (weak_hit is None and miss_surface and
                m_surface == miss_surface and (not miss_fm or not m_fm)):
                weak_hit = (event, matched)
        if strong_hit:
            break
    if strong_hit:
        leaks.append((miss, strong_hit[0], strong_hit[1]))
    elif weak_hit:
        weak_leaks.append((miss, weak_hit[0], weak_hit[1]))

if not leaks and not weak_leaks:
    print("{} miss(es), {} surface event(s); no leaks detected.".format(len(misses), len(events)))
    print("(A leak is a miss whose surface/fm was already surfaced by a prior event.)")
    sys.exit(0)

if leaks:
    print("{} leak(s): failures despite a relevant warning being surfaced earlier.".format(len(leaks)))
    print()
    for miss, event, matched in leaks:
        desc = miss.get("description", "")
        desc = " ".join(desc.split())
        if len(desc) > 70:
            desc = desc[:67] + "..."
        print("  Miss:    {} {}".format(miss.get("id"), desc))
        print("    surface={}  fm={}".format(miss.get("surface", ""), miss.get("fm", "")))
        print("  Was surfaced by event {} at {}".format(event.get("id"), event.get("timestamp")))
        print("    via capture {} (same surface/fm)".format(matched.get("id")))
        print()

if weak_leaks:
    print("{} weak signal(s): surface matched but fm absent on one side.".format(len(weak_leaks)))
    print("(Weak signals are not leaks. Capture fm consistently to upgrade them.)")
    print()
    for miss, event, matched in weak_leaks:
        desc = miss.get("description", "")
        desc = " ".join(desc.split())
        if len(desc) > 70:
            desc = desc[:67] + "..."
        miss_fm_display = miss.get("fm", "") or "(none)"
        matched_fm_display = matched.get("fm", "") or "(none)"
        print("  Miss:    {} {}".format(miss.get("id"), desc))
        print("    surface={}  fm={}".format(miss.get("surface", ""), miss_fm_display))
        print("  Was surfaced by event {} at {}".format(event.get("id"), event.get("timestamp")))
        print("    via capture {} (surface={}, fm={})".format(
            matched.get("id"), matched.get("surface", ""), matched_fm_display))
        print()
PYEOF
        return 0
    fi

    if $recurrence_mode; then
        python3 - "$CMA_DIR" <<'PYEOF'
import json, os, sys
from collections import Counter

data_dir = sys.argv[1]
groups = Counter()
total = 0

misses_path = os.path.join(data_dir, "misses.jsonl")
corrupted = 0
if os.path.exists(misses_path):
    with open(misses_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                corrupted += 1
                continue
            key = (rec.get("surface", ""), rec.get("fm", ""))
            groups[key] += 1
            total += 1

if corrupted:
    print("cma: skipped {} corrupted line(s) in misses.jsonl".format(corrupted), file=sys.stderr)

if total == 0:
    print("No misses recorded yet.")
    sys.exit(0)

recurring = sorted(
    [(k, v) for k, v in groups.items() if v >= 2],
    key=lambda x: x[1], reverse=True
)

if not recurring:
    print("{} miss(es) recorded; no patterns are recurring (threshold: 2+ per surface/fm pair).".format(total))
    sys.exit(0)

print("Recurring failure patterns from {} miss(es):".format(total))
print()
for (surface, fm), count in recurring:
    s = surface if surface else "(no surface)"
    f = fm if fm else "(no fm)"
    print("  {}x  surface={}  fm={}".format(count, s, f))
print()
print("Recurrence indicates the prevention currently in place is not working.")
print("Sharpen the warning, change when it surfaces, or retire it as ineffective.")
PYEOF
        return 0
    fi

    if [[ -n "$view" ]]; then
        cmd_surface --type "$view"
        return 0
    fi

    # Default summary
    echo "Compound practice summary"
    echo ""
    local total=0
    for type in misses decisions rejections preventions core; do
        local count=0
        if [[ -f "$CMA_DIR/$type.jsonl" ]]; then
            count=$(wc -l < "$CMA_DIR/$type.jsonl" | tr -d ' ')
        fi
        printf "  %-13s %s\n" "$type" "$count"
        total=$((total + count))
    done
    echo ""
    printf "  %-13s %s\n" "total" "$total"
}

