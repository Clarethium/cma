warn_if_storage_risky() {
    # Append atomicity is reliable on local POSIX filesystems but
    # weaker on network filesystems (NFS without flock, SMB) and on
    # cloud-sync directories that watch+rewrite files (Dropbox,
    # iCloud Drive, OneDrive, Google Drive). Warn rather than block
    # so operators can override after reading the rationale in
    # DATA.md.
    local dir="$1"
    case "$dir" in
        *Dropbox*|*"iCloud Drive"*|*OneDrive*|*"Google Drive"*|*GoogleDrive*|*pCloudDrive*|*Sync/*)
            echo "cma: warning: $dir looks like a cloud-sync path." >&2
            echo "cma: append atomicity is not guaranteed on synced directories;" >&2
            echo "cma: see DATA.md (Storage requirements) for the rationale." >&2
            return 0
            ;;
    esac
    # Try to detect a network filesystem type via df (best-effort;
    # not all systems support -T). Silent on failure.
    local fs
    fs=$(df -T "$dir" 2>/dev/null | awk 'NR==2 {print tolower($2)}' || true)
    case "$fs" in
        nfs*|cifs|smbfs|fuse.sshfs|fuseblk)
            echo "cma: warning: $dir is on a $fs filesystem." >&2
            echo "cma: append atomicity is not guaranteed on network filesystems;" >&2
            echo "cma: see DATA.md (Storage requirements) for the rationale." >&2
            ;;
    esac
}

cmd_id() {
    # Print the id of the most recent capture matching the filters.
    # Useful for piping into --miss-id / --warning-id / --retire so an
    # operator does not have to scroll back through terminal output.
    #
    #   cma prevented "caught it" --miss-id "$(cma id miss)"
    #   cma prevented "caught it" --miss-id "$(cma id miss --surface auth)"
    local type="miss" surface=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)
                type="$2"; shift 2 ;;
            --surface)
                surface="$2"; shift 2 ;;
            miss|decision|rejection|prevention|core)
                # Allow `cma id miss` shorthand as well as --type miss.
                type="$1"; shift ;;
            *)
                echo "cma id: unknown flag: $1" >&2
                echo "Usage: cma id [miss|decision|rejection|prevention|core] [--surface <s>]" >&2
                exit 1 ;;
        esac
    done
    local file
    case "$type" in
        miss) file="misses.jsonl" ;;
        decision) file="decisions.jsonl" ;;
        rejection) file="rejections.jsonl" ;;
        prevention) file="preventions.jsonl" ;;
        core) file="core.jsonl" ;;
        *) echo "cma id: unknown type: $type" >&2; exit 1 ;;
    esac
    python3 - "$CMA_DIR/$file" "$surface" <<'PYEOF'
import json, os, sys
path, surface = sys.argv[1:]
if not os.path.exists(path):
    sys.exit(1)  # silent; no captures of this type yet
best = None
with open(path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        if rec.get("type") == "retirement":
            continue
        if surface and rec.get("surface") != surface:
            continue
        if best is None or rec.get("timestamp", "") > best.get("timestamp", ""):
            best = rec
if best is None:
    sys.exit(1)
sys.stdout.write(best.get("id", "") + "\n")
PYEOF
}

cmd_install_hook() {
    # Wire cma's action-time injection hooks into the operator's
    # Claude Code settings.json. Idempotent: re-running detects
    # existing cma hooks and skips. Preserves any other hooks the
    # operator has already configured. With --dry-run, prints the
    # merged JSON to stdout without writing.
    local target="" scope="user" dry_run=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --claude-code) target="claude-code"; shift ;;
            --scope)
                if [[ "${2:-}" != "user" && "${2:-}" != "project" ]]; then
                    echo "cma install-hook: --scope must be 'user' or 'project'" >&2; exit 1
                fi
                scope="$2"; shift 2 ;;
            --dry-run) dry_run=true; shift ;;
            *) echo "cma install-hook: unknown flag: $1" >&2
               echo "Usage: cma install-hook --claude-code [--scope user|project] [--dry-run]" >&2
               exit 1 ;;
        esac
    done

    if [[ -z "$target" ]]; then
        echo "cma install-hook: target required" >&2
        echo "Usage: cma install-hook --claude-code [--scope user|project] [--dry-run]" >&2
        exit 1
    fi

    local settings_path
    case "$scope" in
        user)    settings_path="$HOME/.claude/settings.json" ;;
        project) settings_path=".claude/settings.json" ;;
    esac

    local cma_dir
    cma_dir=$(dirname "$(realpath "$0")")
    local session_hook="$cma_dir/hooks/claude-code-session-start.sh"
    local pretool_hook="$cma_dir/hooks/claude-code-pre-tool-use.sh"

    if [[ ! -f "$session_hook" ]]; then
        echo "cma install-hook: session-start hook not found at $session_hook" >&2
        exit 1
    fi
    if [[ ! -f "$pretool_hook" ]]; then
        echo "cma install-hook: pre-tool-use hook not found at $pretool_hook" >&2
        exit 1
    fi

    local mode="write"
    $dry_run && mode="dry"

    python3 - "$settings_path" "$session_hook" "$pretool_hook" "$mode" <<'PYEOF'
import json, os, shutil, sys

settings_path, session_hook, pretool_hook, mode = sys.argv[1:]

existing = {}
if os.path.exists(settings_path):
    try:
        with open(settings_path) as f:
            text = f.read().strip()
        if text:
            existing = json.loads(text)
    except json.JSONDecodeError as e:
        print(f"cma install-hook: cannot parse {settings_path}: {e}", file=sys.stderr)
        print("  Fix the file (or remove it) and re-run; no changes made.", file=sys.stderr)
        sys.exit(1)

hooks = existing.setdefault("hooks", {})
session_list = hooks.setdefault("SessionStart", [])
pretool_list = hooks.setdefault("PreToolUse", [])

def has_cma_hook(hook_list, hook_path):
    for group in hook_list:
        for h in group.get("hooks", []):
            if hook_path in h.get("command", ""):
                return True
    return False

added = []
if not has_cma_hook(session_list, session_hook):
    session_list.append({
        "hooks": [{"type": "command", "command": f"bash {session_hook}"}]
    })
    added.append("SessionStart")
if not has_cma_hook(pretool_list, pretool_hook):
    pretool_list.append({
        "hooks": [{"type": "command", "command": f"bash {pretool_hook}"}]
    })
    added.append("PreToolUse")

merged_json = json.dumps(existing, indent=2)

if mode == "dry":
    print(merged_json)
    if not added:
        print(f"# Hooks already present in {settings_path}; no changes would be written.",
              file=sys.stderr)
    else:
        print(f"# Would add {', '.join(added)} to {settings_path}",
              file=sys.stderr)
    sys.exit(0)

if not added:
    print(f"cma install-hook: hooks already present in {settings_path}; no changes.")
    sys.exit(0)

os.makedirs(os.path.dirname(settings_path) or ".", exist_ok=True)
if os.path.exists(settings_path):
    shutil.copy(settings_path, settings_path + ".bak")
with open(settings_path, "w") as f:
    f.write(merged_json + "\n")

print(f"cma install-hook: wired {', '.join(added)} into {settings_path}")
if os.path.exists(settings_path + ".bak"):
    print(f"  backup of prior contents: {settings_path}.bak")
print("  Claude Code reads settings.json at session start; restart Claude Code to pick up the change.")
PYEOF
}

