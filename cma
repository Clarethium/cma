#!/usr/bin/env bash
# cma - Compound practice loop
# https://github.com/Clarethium/cma
#
# Specification: see DESIGN.md
# Methodology: https://github.com/Clarethium/lodestone

set -euo pipefail

VERSION="1.0.0-dev"
SCHEMA_VERSION="1.0"
CMA_DIR="${CMA_DIR:-$HOME/.cma}"

mkdir -p "$CMA_DIR"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

new_id() {
    printf "%s-%s" "$(date -u +%Y%m%d-%H%M%S)" "$(head -c 4 /dev/urandom | xxd -p)"
}

json_escape() {
    python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"
}

iso_now() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

usage_for() {
    case "$1" in
        miss)
            cat <<'EOF'
cma miss <description>
    [--surface <surface>]
    [--fm <failure-shape>]
    [--files <file>[,<file>...]]
    [--excerpt <text>]       (or --excerpt-from <file>)
    [--intended <text>]      (counterfactual: what was about to happen)
    [--corrected <text>]     (what happened instead after correction)

Capture a failure. The description is required; remaining flags are optional.
Texture fields (excerpt, intended, corrected) preserve the conditions of the
failure so future surfacing can match by situation, not just keywords.
EOF
            ;;
        decision)
            cat <<'EOF'
cma decision <description> [--surface <s>] [--applies-when <predicate>]

Capture an architectural or strategic choice. Format the description as
"TOPIC: choice (rationale)".

The --applies-when predicate is matched against context at action time:
when surface or file context contains any keyword in applies-when, the
decision surfaces alongside other captures. Decisions thus apply when their
conditions are met, not only when explicitly queried.
EOF
            ;;
        reject)
            cat <<'EOF'
cma reject <description> [--surface <s>] [--revisit-when <trigger>]

Capture an eliminated option. Format the description as "OPTION: reason".
EOF
            ;;
        prevented)
            cat <<'EOF'
cma prevented <description> [--miss-id <id>] [--warning-id <id>]

Capture a moment where a surfaced warning prevented a recurrence.
EOF
            ;;
        surface)
            cat <<'EOF'
cma surface [--surface <s>] [--file <f>] [--type <t>] [--limit <n>]

Bring relevant prior captures into view for the current context.
EOF
            ;;
        distill)
            cat <<'EOF'
cma distill <learning> [--scope <s>] [--surface <s>]
cma distill --retire <pattern>
cma distill --review

Promote a learning, retire a learning, or preview accumulated patterns.
EOF
            ;;
        stats)
            cat <<'EOF'
cma stats [--rejections] [--leaks] [--preventions] [--recurrence] [--behavior]
cma stats --evidence [--window <days>]

Evidence dashboard. Default mode shows summary; flags select views.
The --evidence view composes preventions and leaks into a single
prevention-rate signal over a trailing window (default 30 days).
EOF
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Capture: write a record to the appropriate jsonl file
# ---------------------------------------------------------------------------

write_capture() {
    local type="$1"
    local file="$2"
    local description="$3"
    shift 3
    # Remaining args are key/value pairs

    local id timestamp
    id=$(new_id)
    timestamp=$(iso_now)

    # Compose the entire JSON record, then append it via a single write()
    # syscall. POSIX append (>>) is atomic for writes up to PIPE_BUF
    # (typically 4096 bytes on Linux). Texture fields (excerpt, intended,
    # corrected) can exceed this. Using python3's f.write of the full
    # record is a single write() syscall, the best we can do without
    # explicit file locking, and is atomic for the common case.
    local record
    record=$(
        printf '{"schema_version":"%s","type":%s,"id":"%s","timestamp":"%s","description":%s' \
            "$SCHEMA_VERSION" "$(json_escape "$type")" "$id" "$timestamp" "$(json_escape "$description")"
        while [[ $# -gt 1 ]]; do
            local key="$1" value="$2"
            shift 2
            [[ -n "$value" ]] && printf ',%s:%s' "$(json_escape "$key")" "$(json_escape "$value")"
        done
        printf '}'
    )

    # Bash command substitution strips trailing newlines; we add the JSONL
    # record terminator inside the python writer to ensure each record is
    # one line, atomically.
    python3 -c '
import sys
path, data = sys.argv[1], sys.argv[2]
with open(path, "ab") as f:
    f.write((data + "\n").encode("utf-8"))
' "$CMA_DIR/$file" "$record"

    echo "Captured $type $id"
}

cmd_miss() {
    if [[ $# -eq 0 ]]; then usage_for miss; exit 1; fi
    local description="$1"; shift
    local surface="" fm="" files=""
    local excerpt="" intended="" corrected=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --surface) surface="$2"; shift 2 ;;
            --fm) fm="$2"; shift 2 ;;
            --files) files="$2"; shift 2 ;;
            --excerpt) excerpt="$2"; shift 2 ;;
            --excerpt-from)
                if [[ ! -f "$2" ]]; then
                    echo "cma miss: --excerpt-from file not found: $2" >&2; exit 1
                fi
                excerpt=$(cat "$2"); shift 2 ;;
            --intended) intended="$2"; shift 2 ;;
            --corrected) corrected="$2"; shift 2 ;;
            *) echo "cma miss: unknown flag: $1" >&2; usage_for miss; exit 1 ;;
        esac
    done

    # Plugin point: when --fm is not provided and CMA_FM_CLASSIFIER is set,
    # invoke the classifier with description on stdin and use its first
    # line of output as the fm tag. Failure-isolated: classifier errors,
    # missing commands, or timeouts do not block the capture.
    # See ARCHITECTURE.md Section 9 (Methodology integration).
    if [[ -z "$fm" ]] && [[ -n "${CMA_FM_CLASSIFIER:-}" ]]; then
        fm=$(printf '%s' "$description" | timeout 5 sh -c "$CMA_FM_CLASSIFIER" 2>/dev/null | head -1 || true)
        # Trim leading/trailing whitespace
        fm="${fm#"${fm%%[![:space:]]*}"}"
        fm="${fm%"${fm##*[![:space:]]}"}"
    fi

    write_capture miss misses.jsonl "$description" \
        surface "$surface" fm "$fm" files "$files" \
        excerpt "$excerpt" intended "$intended" corrected "$corrected"
}

cmd_decision() {
    if [[ $# -eq 0 ]]; then usage_for decision; exit 1; fi
    local description="$1"; shift
    local surface="" applies_when=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --surface) surface="$2"; shift 2 ;;
            --applies-when) applies_when="$2"; shift 2 ;;
            *) echo "cma decision: unknown flag: $1" >&2; usage_for decision; exit 1 ;;
        esac
    done
    write_capture decision decisions.jsonl "$description" \
        surface "$surface" applies_when "$applies_when"
}

cmd_reject() {
    if [[ $# -eq 0 ]]; then usage_for reject; exit 1; fi
    local description="$1"; shift
    local surface="" revisit_when=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --surface) surface="$2"; shift 2 ;;
            --revisit-when) revisit_when="$2"; shift 2 ;;
            *) echo "cma reject: unknown flag: $1" >&2; usage_for reject; exit 1 ;;
        esac
    done
    write_capture rejection rejections.jsonl "$description" \
        surface "$surface" revisit_when "$revisit_when"
}

cmd_prevented() {
    if [[ $# -eq 0 ]]; then usage_for prevented; exit 1; fi
    local description="$1"; shift
    local miss_id="" warning_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --miss-id) miss_id="$2"; shift 2 ;;
            --warning-id) warning_id="$2"; shift 2 ;;
            *) echo "cma prevented: unknown flag: $1" >&2; usage_for prevented; exit 1 ;;
        esac
    done
    write_capture prevention preventions.jsonl "$description" \
        miss_id "$miss_id" warning_id "$warning_id"
}

# ---------------------------------------------------------------------------
# Operational verbs (stubbed for v1.0-dev)
# ---------------------------------------------------------------------------

cmd_surface() {
    local surface="" file="" type="" limit="10" log_event=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --surface) surface="$2"; shift 2 ;;
            --file) file="$2"; shift 2 ;;
            --type) type="$2"; shift 2 ;;
            --limit) limit="$2"; shift 2 ;;
            --no-log) log_event=false; shift ;;
            *) echo "cma surface: unknown flag: $1" >&2; usage_for surface; exit 1 ;;
        esac
    done

    local log_arg="log"
    $log_event || log_arg="nolog"

    python3 - "$CMA_DIR" "$surface" "$file" "$type" "$limit" "$log_arg" <<'PYEOF'
import json, os, sys, time
from glob import glob

data_dir, surface_filter, file_filter, type_filter, limit_str, log_arg = sys.argv[1:]
limit = int(limit_str) if limit_str else 10
should_log = (log_arg == "log")

captures = []
for path in sorted(glob(os.path.join(data_dir, "*.jsonl"))):
    # Don't include surface_events.jsonl in the captures-to-surface set
    if os.path.basename(path) == "surface_events.jsonl":
        continue
    corrupted = 0
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                corrupted += 1
                continue
            # Skip retirement records when surfacing
            if rec.get("type") == "retirement":
                continue
            captures.append(rec)
    if corrupted:
        print("cma: skipped {} corrupted line(s) in {}".format(corrupted, os.path.basename(path)), file=sys.stderr)

def matches(rec):
    if type_filter and rec.get("type") != type_filter:
        return False

    # Decisions: applies-when matches against context keywords. A decision
    # with applies-when="auth db" surfaces whenever surface or file context
    # contains "auth" or "db", even if the decision's own surface differs.
    # This closes the decision-surfacing loop (decisions surface at action
    # time when conditions match, not just by stored surface field).
    if rec.get("type") == "decision":
        applies_when = (rec.get("applies_when") or "").lower()
        if applies_when:
            keywords = [k for k in applies_when.replace(",", " ").split() if k]
            context_parts = []
            if surface_filter: context_parts.append(surface_filter.lower())
            if file_filter: context_parts.append(file_filter.lower())
            context_str = " ".join(context_parts)
            if context_str and any(kw in context_str for kw in keywords):
                return True

    if surface_filter and rec.get("surface") != surface_filter:
        return False
    if file_filter:
        files = rec.get("files", "")
        if file_filter not in files:
            return False
    return True

filtered = [r for r in captures if matches(r)]
filtered.sort(key=lambda r: r.get("timestamp", ""), reverse=True)
filtered = filtered[:limit]

# Log the surface event so cma stats --leaks can later detect failures
# that occurred despite a relevant warning being surfaced.
if should_log:
    event_id = "{}-{}".format(time.strftime("%Y%m%d-%H%M%S", time.gmtime()), os.urandom(4).hex())
    event = {
        "schema_version": "1.0",
        "type": "surface_event",
        "id": event_id,
        "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "filter_surface": surface_filter,
        "filter_file": file_filter,
        "filter_type": type_filter,
        "filter_limit": limit,
        "matched": [
            {
                "id": r.get("id"),
                "type": r.get("type"),
                "surface": r.get("surface", ""),
                "fm": r.get("fm", ""),
            }
            for r in filtered
        ],
    }
    log_path = os.path.join(data_dir, "surface_events.jsonl")
    with open(log_path, "a") as f:
        f.write(json.dumps(event) + "\n")

if not filtered:
    print("No captures match.")
    sys.exit(0)

for rec in filtered:
    type_label = rec.get("type", "?")
    rec_id = rec.get("id", "?")
    surface = rec.get("surface", "")
    desc = rec.get("description", "")
    desc = " ".join(desc.split())
    if len(desc) > 96:
        desc = desc[:93] + "..."
    surface_part = " [" + surface + "]" if surface else ""
    print(type_label.ljust(10) + " " + rec_id + surface_part)
    print("           " + desc)
    print()
PYEOF
}

cmd_distill() {
    local retire_pattern="" review_mode=false
    local learning="" scope="" surface=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --retire) retire_pattern="$2"; shift 2 ;;
            --review) review_mode=true; shift ;;
            --scope) scope="$2"; shift 2 ;;
            --surface) surface="$2"; shift 2 ;;
            -*) echo "cma distill: unknown flag: $1" >&2; usage_for distill; exit 1 ;;
            *)
                if [[ -z "$learning" ]]; then learning="$1"; else
                    echo "cma distill: extra positional argument: $1" >&2; exit 1
                fi
                shift ;;
        esac
    done

    if $review_mode; then
        python3 - "$CMA_DIR" <<'PYEOF'
import json, os, sys
from collections import Counter

data_dir = sys.argv[1]
groups = Counter()
total = 0

misses_path = os.path.join(data_dir, "misses.jsonl")
corrupted = 0
if os.path.exists(misses_path):
    with open(misses_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                corrupted += 1
                continue
            key = (rec.get("surface", ""), rec.get("fm", ""))
            groups[key] += 1
            total += 1

if corrupted:
    print("cma: skipped {} corrupted line(s) in misses.jsonl".format(corrupted), file=sys.stderr)

if total == 0:
    print("No misses recorded yet.")
    sys.exit(0)

candidates = sorted(
    [(k, v) for k, v in groups.items() if v >= 2],
    key=lambda x: x[1], reverse=True
)

if not candidates:
    print("{} miss(es) recorded; no patterns recur yet (need 2+ per surface/fm).".format(total))
    sys.exit(0)

print("Distillation candidates from {} miss(es):".format(total))
print()
for (surface, fm), count in candidates:
    s = surface if surface else "(no surface)"
    f = fm if fm else "(no fm)"
    print("  {}x  surface={}  fm={}".format(count, s, f))
print()
print("Use 'cma distill <learning>' to promote a rule for one of these patterns.")
PYEOF
        return 0
    fi

    if [[ -n "$retire_pattern" ]]; then
        python3 - "$CMA_DIR" "$retire_pattern" <<'PYEOF'
import json, os, sys, time

data_dir, pattern = sys.argv[1:3]
core_path = os.path.join(data_dir, "core.jsonl")

if not os.path.exists(core_path):
    print("No core learnings to retire.")
    sys.exit(0)

retired_ids = set()
with open(core_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        if rec.get("type") == "retirement":
            retired_ids.add(rec.get("retires"))

matched = []
with open(core_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
        except json.JSONDecodeError:
            continue
        if rec.get("type") != "core":
            continue
        rid = rec.get("id")
        if rid in retired_ids:
            continue
        if pattern in rec.get("description", ""):
            matched.append(rec)

if not matched:
    print("No active core learnings matched: {}".format(pattern))
    sys.exit(0)

now = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
with open(core_path, "a") as f:
    for rec in matched:
        retire_id = "{}-{}".format(time.strftime("%Y%m%d-%H%M%S", time.gmtime()), os.urandom(4).hex())
        retirement = {
            "type": "retirement",
            "id": retire_id,
            "timestamp": now,
            "retires": rec.get("id"),
            "pattern": pattern,
        }
        f.write(json.dumps(retirement) + "\n")

print("Retired {} core learning(s) matching: {}".format(len(matched), pattern))
for rec in matched:
    desc = rec.get("description", "")
    if len(desc) > 70:
        desc = desc[:67] + "..."
    print("  - {} {}".format(rec.get("id"), desc))
